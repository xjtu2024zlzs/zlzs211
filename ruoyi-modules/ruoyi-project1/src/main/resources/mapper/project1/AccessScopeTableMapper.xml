            <if test="sourceDatabase != null">#{sourceDatabase},</if>
            <if test="sourceTable != null and sourceTable != ''">#{sourceTable},</if>
            <if test="targetTable != null and targetTable != ''">#{targetTable},</if>
            <if test="sourceEntityId != null">#{sourceEntityId},</if>
            <if test="fieldMappingCount != null">#{fieldMappingCount},</if>
            <if test="scopeStatus != null">#{scopeStatus},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateAccessScopeTable" parameterType="AccessScopeTable">
        update p1p_access_scope_table
