            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where scope_table_id = #{scopeTableId}
    </update>

    <delete id="deleteAccessScopeTableByScopeTableId" parameterType="Long">
        delete from p1p_access_scope_table where scope_table_id = #{scopeTableId}
    </delete>

    <delete id="deleteAccessScopeTableByScopeTableIds" parameterType="String">
        delete from p1p_access_scope_table where scope_table_id in 
        <foreach item="scopeTableId" collection="array" open="(" separator="," close=")">
            #{scopeTableId}
        </foreach>
    </delete>
