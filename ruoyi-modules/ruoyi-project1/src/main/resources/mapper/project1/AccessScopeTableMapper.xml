    <sql id="selectAccessScopeTableVo">
        select scope_table_id, access_plan_id, spec_set_id, source_datasource_id, source_database, source_table, target_table, source_entity_id, field_mapping_count, scope_status, create_time, update_time, remark from p1p_access_scope_table
    </sql>

    <select id="selectAccessScopeTableList" parameterType="AccessScopeTable" resultMap="AccessScopeTableResult">
        <include refid="selectAccessScopeTableVo"/>
        <where>  
            <if test="accessPlanId != null "> and access_plan_id = #{accessPlanId}</if>
            <if test="specSetId != null "> and spec_set_id = #{specSetId}</if>
            <if test="sourceDatasourceId != null "> and source_datasource_id = #{sourceDatasourceId}</if>
            <if test="sourceDatabase != null  and sourceDatabase != ''"> and source_database = #{sourceDatabase}</if>
            <if test="sourceTable != null  and sourceTable != ''"> and source_table = #{sourceTable}</if>
            <if test="targetTable != null  and targetTable != ''"> and target_table = #{targetTable}</if>
            <if test="sourceEntityId != null "> and source_entity_id = #{sourceEntityId}</if>
            <if test="fieldMappingCount != null "> and field_mapping_count = #{fieldMappingCount}</if>
            <if test="scopeStatus != null  and scopeStatus != ''"> and scope_status = #{scopeStatus}</if>
        </where>
    </select>
    
    <select id="selectAccessScopeTableByScopeTableId" parameterType="Long" resultMap="AccessScopeTableResult">
        <include refid="selectAccessScopeTableVo"/>
        where scope_table_id = #{scopeTableId}
    </select>

    <insert id="insertAccessScopeTable" parameterType="AccessScopeTable" useGeneratedKeys="true" keyProperty="scopeTableId">
        insert into p1p_access_scope_table
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="accessPlanId != null">access_plan_id,</if>
            <if test="specSetId != null">spec_set_id,</if>
            <if test="sourceDatasourceId != null">source_datasource_id,</if>
            <if test="sourceDatabase != null">source_database,</if>
            <if test="sourceTable != null and sourceTable != ''">source_table,</if>
            <if test="targetTable != null and targetTable != ''">target_table,</if>
            <if test="sourceEntityId != null">source_entity_id,</if>
            <if test="fieldMappingCount != null">field_mapping_count,</if>
            <if test="scopeStatus != null">scope_status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
