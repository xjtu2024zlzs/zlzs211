<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project1.mapper.MatchTaskMapper">
    
    <resultMap type="MatchTask" id="MatchTaskResult">
        <result property="taskId"    column="task_id"    />
        <result property="taskName"    column="task_name"    />
        <result property="currentVersionId"    column="current_version_id"    />
        <result property="sourceDatasourceId"    column="source_datasource_id"    />
        <result property="lifecycleStatus"    column="lifecycle_status"    />
        <result property="lastRecordStatus"    column="last_record_status"    />
        <result property="lastRecordStage"    column="last_record_stage"    />
        <result property="status"    column="status"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectMatchTaskVo">
        select task_id, task_name, current_version_id, source_datasource_id, lifecycle_status, last_record_status, last_record_stage, status, del_flag, create_by, create_time, update_by, update_time, remark from p1p_match_task
    </sql>

    <select id="selectMatchTaskList" parameterType="MatchTask" resultMap="MatchTaskResult">
        <include refid="selectMatchTaskVo"/>
        <where>  
            <if test="taskName != null  and taskName != ''"> and task_name like concat('%', #{taskName}, '%')</if>
            <if test="currentVersionId != null "> and current_version_id = #{currentVersionId}</if>
            <if test="sourceDatasourceId != null "> and source_datasource_id = #{sourceDatasourceId}</if>
            <if test="lifecycleStatus != null  and lifecycleStatus != ''"> and lifecycle_status = #{lifecycleStatus}</if>
            <if test="lastRecordStatus != null  and lastRecordStatus != ''"> and last_record_status = #{lastRecordStatus}</if>
            <if test="lastRecordStage != null  and lastRecordStage != ''"> and last_record_stage = #{lastRecordStage}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectMatchTaskByTaskId" parameterType="Long" resultMap="MatchTaskResult">
        <include refid="selectMatchTaskVo"/>
        where task_id = #{taskId}
    </select>

    <insert id="insertMatchTask" parameterType="MatchTask" useGeneratedKeys="true" keyProperty="taskId">
        insert into p1p_match_task
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskName != null and taskName != ''">task_name,</if>
            <if test="currentVersionId != null">current_version_id,</if>
            <if test="sourceDatasourceId != null">source_datasource_id,</if>
            <if test="lifecycleStatus != null and lifecycleStatus != ''">lifecycle_status,</if>
            <if test="lastRecordStatus != null">last_record_status,</if>
            <if test="lastRecordStage != null">last_record_stage,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="taskName != null and taskName != ''">#{taskName},</if>
            <if test="currentVersionId != null">#{currentVersionId},</if>
            <if test="sourceDatasourceId != null">#{sourceDatasourceId},</if>
            <if test="lifecycleStatus != null and lifecycleStatus != ''">#{lifecycleStatus},</if>
            <if test="lastRecordStatus != null">#{lastRecordStatus},</if>
            <if test="lastRecordStage != null">#{lastRecordStage},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateMatchTask" parameterType="MatchTask">
        update p1p_match_task
        <trim prefix="SET" suffixOverrides=",">
            <if test="taskName != null and taskName != ''">task_name = #{taskName},</if>
            <if test="currentVersionId != null">current_version_id = #{currentVersionId},</if>
            <if test="sourceDatasourceId != null">source_datasource_id = #{sourceDatasourceId},</if>
            <if test="lifecycleStatus != null and lifecycleStatus != ''">lifecycle_status = #{lifecycleStatus},</if>
            <if test="lastRecordStatus != null">last_record_status = #{lastRecordStatus},</if>
            <if test="lastRecordStage != null">last_record_stage = #{lastRecordStage},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where task_id = #{taskId}
    </update>

    <delete id="deleteMatchTaskByTaskId" parameterType="Long">
        delete from p1p_match_task where task_id = #{taskId}
    </delete>

    <delete id="deleteMatchTaskByTaskIds" parameterType="String">
        delete from p1p_match_task where task_id in 
        <foreach item="taskId" collection="array" open="(" separator="," close=")">
            #{taskId}
        </foreach>
    </delete>
</mapper>