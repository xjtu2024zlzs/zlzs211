<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project1.mapper.DatasourceMapper">
    
    <resultMap type="Datasource" id="DatasourceResult">
        <result property="datasourceId"    column="datasource_id"    />
        <result property="datasourceName"    column="datasource_name"    />
        <result property="accessMode"    column="access_mode"    />
        <result property="useStatus"    column="use_status"    />
        <result property="connectionStatus"    column="connection_status"    />
        <result property="lastTestTime"    column="last_test_time"    />
        <result property="lastTestMessage"    column="last_test_message"    />
        <result property="latestSchemaSnapshotId"    column="latest_schema_snapshot_id"    />
        <result property="status"    column="status"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectDatasourceVo">
        select datasource_id, datasource_name, access_mode, use_status, connection_status, last_test_time, last_test_message, latest_schema_snapshot_id, status, del_flag, create_by, create_time, update_by, update_time, remark from p1p_datasource
    </sql>

    <select id="selectDatasourceList" parameterType="Datasource" resultMap="DatasourceResult">
        <include refid="selectDatasourceVo"/>
        <where>  
            <if test="datasourceName != null  and datasourceName != ''"> and datasource_name like concat('%', #{datasourceName}, '%')</if>
            <if test="accessMode != null  and accessMode != ''"> and access_mode = #{accessMode}</if>
            <if test="useStatus != null  and useStatus != ''"> and use_status = #{useStatus}</if>
            <if test="connectionStatus != null  and connectionStatus != ''"> and connection_status = #{connectionStatus}</if>
            <if test="lastTestTime != null "> and last_test_time = #{lastTestTime}</if>
            <if test="lastTestMessage != null  and lastTestMessage != ''"> and last_test_message = #{lastTestMessage}</if>
            <if test="latestSchemaSnapshotId != null "> and latest_schema_snapshot_id = #{latestSchemaSnapshotId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectDatasourceByDatasourceId" parameterType="Long" resultMap="DatasourceResult">
        <include refid="selectDatasourceVo"/>
        where datasource_id = #{datasourceId}
    </select>

    <insert id="insertDatasource" parameterType="Datasource" useGeneratedKeys="true" keyProperty="datasourceId">
        insert into p1p_datasource
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="datasourceName != null and datasourceName != ''">datasource_name,</if>
            <if test="accessMode != null and accessMode != ''">access_mode,</if>
            <if test="useStatus != null and useStatus != ''">use_status,</if>
            <if test="connectionStatus != null and connectionStatus != ''">connection_status,</if>
            <if test="lastTestTime != null">last_test_time,</if>
            <if test="lastTestMessage != null">last_test_message,</if>
            <if test="latestSchemaSnapshotId != null">latest_schema_snapshot_id,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="datasourceName != null and datasourceName != ''">#{datasourceName},</if>
            <if test="accessMode != null and accessMode != ''">#{accessMode},</if>
            <if test="useStatus != null and useStatus != ''">#{useStatus},</if>
            <if test="connectionStatus != null and connectionStatus != ''">#{connectionStatus},</if>
            <if test="lastTestTime != null">#{lastTestTime},</if>
            <if test="lastTestMessage != null">#{lastTestMessage},</if>
            <if test="latestSchemaSnapshotId != null">#{latestSchemaSnapshotId},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateDatasource" parameterType="Datasource">
        update p1p_datasource
        <trim prefix="SET" suffixOverrides=",">
            <if test="datasourceName != null and datasourceName != ''">datasource_name = #{datasourceName},</if>
            <if test="accessMode != null and accessMode != ''">access_mode = #{accessMode},</if>
            <if test="useStatus != null and useStatus != ''">use_status = #{useStatus},</if>
            <if test="connectionStatus != null and connectionStatus != ''">connection_status = #{connectionStatus},</if>
            <if test="lastTestTime != null">last_test_time = #{lastTestTime},</if>
            <if test="lastTestMessage != null">last_test_message = #{lastTestMessage},</if>
            <if test="latestSchemaSnapshotId != null">latest_schema_snapshot_id = #{latestSchemaSnapshotId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where datasource_id = #{datasourceId}
    </update>

    <delete id="deleteDatasourceByDatasourceId" parameterType="Long">
        delete from p1p_datasource where datasource_id = #{datasourceId}
    </delete>

    <delete id="deleteDatasourceByDatasourceIds" parameterType="String">
        delete from p1p_datasource where datasource_id in 
        <foreach item="datasourceId" collection="array" open="(" separator="," close=")">
            #{datasourceId}
        </foreach>
    </delete>
</mapper>