<mapper namespace="com.ruoyi.project1.mapper.ReviewedMatchMapper">
    
    <resultMap type="ReviewedMatch" id="ReviewedMatchResult">
        <result property="reviewId"    column="review_id"    />
        <result property="taskId"    column="task_id"    />
        <result property="versionId"    column="version_id"    />
        <result property="recordId"    column="record_id"    />
        <result property="resultSetId"    column="result_set_id"    />
        <result property="resultRowId"    column="result_row_id"    />
        <result property="sourceDatasourceId"    column="source_datasource_id"    />
        <result property="sourceDatabase"    column="source_database"    />
        <result property="sourceTable"    column="source_table"    />
        <result property="sourceColumn"    column="source_column"    />
        <result property="proposedTargetTable"    column="proposed_target_table"    />
        <result property="proposedTargetColumn"    column="proposed_target_column"    />
        <result property="targetTable"    column="target_table"    />
        <result property="targetColumn"    column="target_column"    />
        <result property="mappingType"    column="mapping_type"    />
        <result property="algorithmScore"    column="algorithm_score"    />
        <result property="reviewStatus"    column="review_status"    />
        <result property="reviewedBy"    column="reviewed_by"    />
        <result property="reviewedAt"    column="reviewed_at"    />
        <result property="createTime"    column="create_time"    />
