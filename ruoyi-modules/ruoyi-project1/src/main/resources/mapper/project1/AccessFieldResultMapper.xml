    </sql>

    <select id="selectAccessFieldResultList" parameterType="AccessFieldResult" resultMap="AccessFieldResultResult">
        <include refid="selectAccessFieldResultVo"/>
        <where>  
            <if test="tableResultId != null "> and table_result_id = #{tableResultId}</if>
            <if test="accessBatchId != null "> and access_batch_id = #{accessBatchId}</if>
            <if test="accessPlanId != null "> and access_plan_id = #{accessPlanId}</if>
            <if test="scopeFieldId != null "> and scope_field_id = #{scopeFieldId}</if>
