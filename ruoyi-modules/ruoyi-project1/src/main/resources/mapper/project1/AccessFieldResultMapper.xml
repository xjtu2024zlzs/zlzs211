            <if test="successCount != null "> and success_count = #{successCount}</if>
            <if test="failedCount != null "> and failed_count = #{failedCount}</if>
            <if test="errorMessage != null  and errorMessage != ''"> and error_message = #{errorMessage}</if>
        </where>
    </select>
    
    <select id="selectAccessFieldResultByFieldResultId" parameterType="Long" resultMap="AccessFieldResultResult">
