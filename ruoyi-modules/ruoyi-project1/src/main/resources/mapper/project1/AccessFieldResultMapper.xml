            <if test="mappingType != null and mappingType != ''">mapping_type = #{mappingType},</if>
            <if test="transformStatus != null and transformStatus != ''">transform_status = #{transformStatus},</if>
            <if test="successCount != null">success_count = #{successCount},</if>
            <if test="failedCount != null">failed_count = #{failedCount},</if>
