<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.designtask1.mapper.DesignTaskLogMapper">

    <resultMap type="DesignTaskLog" id="DesignTaskLogResult">
        <id property="logId" column="log_id" />
        <result property="taskId" column="task_id" />
        <result property="nodeId" column="node_id" />
        <result property="action" column="action" />
        <result property="content" column="content" />
        <result property="operatorId" column="operator_id" />
        <result property="operatorName" column="operator_name" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="selectLogVo">
        select log_id, task_id, node_id, action, content, operator_id, operator_name, create_time
        from t2_design_task_log
    </sql>

    <select id="selectLogList" parameterType="DesignTaskLog" resultMap="DesignTaskLogResult">
        <include refid="selectLogVo"/>
        <where>
            <if test="taskId != null">AND task_id = #{taskId}</if>
            <if test="action != null and action != ''">AND action = #{action}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectLogsByTaskId" parameterType="Long" resultMap="DesignTaskLogResult">
        <include refid="selectLogVo"/>
        where task_id = #{taskId}
        order by create_time desc
    </select>

    <insert id="insertLog" parameterType="DesignTaskLog" useGeneratedKeys="true" keyProperty="logId">
        insert into t2_design_task_log(
            <if test="logId != null and logId != 0">log_id,</if>
            <if test="taskId != null">task_id,</if>
            <if test="nodeId != null">node_id,</if>
            <if test="action != null and action != ''">action,</if>
            <if test="content != null">content,</if>
            <if test="operatorId != null">operator_id,</if>
            <if test="operatorName != null">operator_name,</if>
            create_time
        )values(
            <if test="logId != null and logId != 0">#{logId},</if>
            <if test="taskId != null">#{taskId},</if>
            <if test="nodeId != null">#{nodeId},</if>
            <if test="action != null and action != ''">#{action},</if>
            <if test="content != null">#{content},</if>
            <if test="operatorId != null">#{operatorId},</if>
            <if test="operatorName != null">#{operatorName},</if>
            sysdate()
        )
    </insert>

    <delete id="deleteLogById" parameterType="Long">
        delete from t2_design_task_log where log_id = #{logId}
    </delete>

    <delete id="deleteLogsByTaskId" parameterType="Long">
        delete from t2_design_task_log where task_id = #{taskId}
    </delete>

</mapper>
