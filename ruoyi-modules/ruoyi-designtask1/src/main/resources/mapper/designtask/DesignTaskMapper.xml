<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.designtask1.mapper.DesignTaskMapper">

    <resultMap type="DesignTask" id="DesignTaskResult">
        <id property="taskId" column="task_id" />
        <result property="taskName" column="task_name" />
        <result property="taskNo" column="task_no" />
        <result property="taskType" column="task_type" />
        <result property="templateId" column="template_id" />
        <result property="priority" column="priority" />
        <result property="description" column="description" />
        <result property="plannedStartTime" column="planned_start_time" />
        <result property="plannedEndTime" column="planned_end_time" />
        <result property="status" column="status" />
        <result property="responsibleRole" column="responsible_role" />
        <result property="collabRoles" column="collab_roles" />
        <result property="processDefinitionId" column="process_definition_id" />
        <result property="processInstanceId" column="process_instance_id" />
        <result property="currentFlowableTaskId" column="current_flowable_task_id" />
        <result property="currentNodeKey" column="current_node_key" />
        <result property="currentNodeName" column="current_node_name" />
        <result property="ownerUserId" column="owner_user_id" />
        <result property="ownerUserName" column="owner_user_name" />
        <result property="structureUserId" column="structure_user_id" />
        <result property="layoutUserId" column="layout_user_id" />
        <result property="aeroUserId" column="aero_user_id" />
        <result property="hydraulicUserId" column="hydraulic_user_id" />
        <result property="manufacturingUserId" column="manufacturing_user_id" />
        <result property="designUserId" column="design_user_id" />
        <result property="leaderUserId" column="leader_user_id" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="delFlag" column="del_flag" />
    </resultMap>

    <sql id="selectTaskVo">
        select task_id, task_name, task_no, task_type, template_id, priority, description,
               planned_start_time, planned_end_time, status,
               responsible_role, collab_roles, process_definition_id, process_instance_id, current_flowable_task_id,
               current_node_key, current_node_name, owner_user_id, owner_user_name,
               structure_user_id, layout_user_id, aero_user_id, hydraulic_user_id,
               manufacturing_user_id, design_user_id, leader_user_id, create_by, create_time, update_by, update_time, del_flag
        from t2_design_task
    </sql>

    <select id="selectTaskList" parameterType="DesignTask" resultMap="DesignTaskResult">
        <include refid="selectTaskVo"/>
        <where>
            <if test="taskName != null and taskName != ''">
                AND task_name like concat('%', #{taskName}, '%')
            </if>
            <if test="taskNo != null and taskNo != ''">
                AND task_no like concat('%', #{taskNo}, '%')
            </if>
            <if test="taskType != null and taskType != ''">
                AND task_type = #{taskType}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="priority != null">
                AND priority = #{priority}
            </if>
            AND del_flag = '0'
        </where>
        order by create_time desc
    </select>

    <select id="selectTaskById" parameterType="Long" resultMap="DesignTaskResult">
        <include refid="selectTaskVo"/>
        where task_id = #{taskId}
    </select>

    <select id="selectTaskByNo" parameterType="String" resultMap="DesignTaskResult">
        <include refid="selectTaskVo"/>
        where task_no = #{taskNo} and del_flag = '0'
    </select>

    <select id="selectTaskByStatus" parameterType="String" resultMap="DesignTaskResult">
        <include refid="selectTaskVo"/>
        where status = #{status} and del_flag = '0'
        order by create_time desc
    </select>

    <select id="checkTaskNameUnique" parameterType="String" resultMap="DesignTaskResult">
        <include refid="selectTaskVo"/>
        where task_name = #{taskName} and del_flag = '0'
    </select>

    <insert id="insertTask" parameterType="DesignTask" useGeneratedKeys="true" keyProperty="taskId">
        insert into t2_design_task(
            <if test="taskName != null and taskName != ''">task_name,</if>
            <if test="taskNo != null and taskNo != ''">task_no,</if>
            <if test="taskType != null and taskType != ''">task_type,</if>
            <if test="templateId != null">template_id,</if>
            <if test="priority != null">priority,</if>
            <if test="description != null">description,</if>
            <if test="plannedStartTime != null">planned_start_time,</if>
            <if test="plannedEndTime != null">planned_end_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="responsibleRole != null">responsible_role,</if>
            <if test="collabRoles != null">collab_roles,</if>
            <if test="processDefinitionId != null">process_definition_id,</if>
            <if test="processInstanceId != null">process_instance_id,</if>
            <if test="currentFlowableTaskId != null">current_flowable_task_id,</if>
            <if test="currentNodeKey != null">current_node_key,</if>
            <if test="currentNodeName != null">current_node_name,</if>
            <if test="ownerUserId != null">owner_user_id,</if>
            <if test="ownerUserName != null">owner_user_name,</if>
            <if test="structureUserId != null">structure_user_id,</if>
            <if test="layoutUserId != null">layout_user_id,</if>
            <if test="aeroUserId != null">aero_user_id,</if>
            <if test="hydraulicUserId != null">hydraulic_user_id,</if>
            <if test="manufacturingUserId != null">manufacturing_user_id,</if>
            <if test="designUserId != null">design_user_id,</if>
            <if test="leaderUserId != null">leader_user_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="taskName != null and taskName != ''">#{taskName},</if>
            <if test="taskNo != null and taskNo != ''">#{taskNo},</if>
            <if test="taskType != null and taskType != ''">#{taskType},</if>
            <if test="templateId != null">#{templateId},</if>
            <if test="priority != null">#{priority},</if>
            <if test="description != null">#{description},</if>
            <if test="plannedStartTime != null">#{plannedStartTime},</if>
            <if test="plannedEndTime != null">#{plannedEndTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="responsibleRole != null">#{responsibleRole},</if>
            <if test="collabRoles != null">#{collabRoles},</if>
            <if test="processDefinitionId != null">#{processDefinitionId},</if>
            <if test="processInstanceId != null">#{processInstanceId},</if>
            <if test="currentFlowableTaskId != null">#{currentFlowableTaskId},</if>
            <if test="currentNodeKey != null">#{currentNodeKey},</if>
            <if test="currentNodeName != null">#{currentNodeName},</if>
            <if test="ownerUserId != null">#{ownerUserId},</if>
            <if test="ownerUserName != null">#{ownerUserName},</if>
            <if test="structureUserId != null">#{structureUserId},</if>
            <if test="layoutUserId != null">#{layoutUserId},</if>
            <if test="aeroUserId != null">#{aeroUserId},</if>
            <if test="hydraulicUserId != null">#{hydraulicUserId},</if>
            <if test="manufacturingUserId != null">#{manufacturingUserId},</if>
            <if test="designUserId != null">#{designUserId},</if>
            <if test="leaderUserId != null">#{leaderUserId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateTask" parameterType="DesignTask">
        update t2_design_task
        <set>
            <if test="taskName != null and taskName != ''">task_name = #{taskName},</if>
            <if test="taskType != null and taskType != ''">task_type = #{taskType},</if>
            <if test="templateId != null">template_id = #{templateId},</if>
            <if test="priority != null">priority = #{priority},</if>
            <if test="description != null">description = #{description},</if>
            <if test="plannedStartTime != null">planned_start_time = #{plannedStartTime},</if>
            <if test="plannedEndTime != null">planned_end_time = #{plannedEndTime},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="responsibleRole != null">responsible_role = #{responsibleRole},</if>
            <if test="collabRoles != null">collab_roles = #{collabRoles},</if>
            <if test="processDefinitionId != null">process_definition_id = #{processDefinitionId},</if>
            <if test="processInstanceId != null">process_instance_id = #{processInstanceId},</if>
            <if test="currentFlowableTaskId != null">current_flowable_task_id = #{currentFlowableTaskId},</if>
            <if test="currentNodeKey != null">current_node_key = #{currentNodeKey},</if>
            <if test="currentNodeName != null">current_node_name = #{currentNodeName},</if>
            <if test="ownerUserId != null">owner_user_id = #{ownerUserId},</if>
            <if test="ownerUserName != null">owner_user_name = #{ownerUserName},</if>
            <if test="structureUserId != null">structure_user_id = #{structureUserId},</if>
            <if test="layoutUserId != null">layout_user_id = #{layoutUserId},</if>
            <if test="aeroUserId != null">aero_user_id = #{aeroUserId},</if>
            <if test="hydraulicUserId != null">hydraulic_user_id = #{hydraulicUserId},</if>
            <if test="manufacturingUserId != null">manufacturing_user_id = #{manufacturingUserId},</if>
            <if test="designUserId != null">design_user_id = #{designUserId},</if>
            <if test="leaderUserId != null">leader_user_id = #{leaderUserId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where task_id = #{taskId}
    </update>

    <delete id="deleteTaskById" parameterType="Long">
        update t2_design_task set del_flag = '2' where task_id = #{taskId}
    </delete>

    <delete id="deleteTaskByIds" parameterType="Long">
        update t2_design_task set del_flag = '2' where task_id in
        <foreach collection="array" item="taskId" open="(" separator="," close=")">
            #{taskId}
        </foreach>
    </delete>

</mapper>
