<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.designtask1.mapper.DesignTemplateNodeMapper">

    <resultMap type="DesignTemplateNode" id="DesignTemplateNodeResult">
        <id property="nodeId" column="node_id" />
        <result property="templateId" column="template_id" />
        <result property="nodeCode" column="node_code" />
        <result property="nodeName" column="node_name" />
        <result property="nodeOrder" column="node_order" />
        <result property="parallelGroup" column="parallel_group" />
        <result property="responsibleRole" column="responsible_role" />
        <result property="timeLimit" column="time_limit" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectNodeVo">
        select node_id, template_id, node_code, node_name, node_order, parallel_group, responsible_role, time_limit, create_by, create_time, update_by, update_time
        from t2_design_template_node
    </sql>

    <select id="selectNodeList" parameterType="DesignTemplateNode" resultMap="DesignTemplateNodeResult">
        <include refid="selectNodeVo"/>
        <where>
            <if test="templateId != null">AND template_id = #{templateId}</if>
            <if test="nodeCode != null and nodeCode != ''">AND node_code = #{nodeCode}</if>
            <if test="nodeName != null and nodeName != ''">AND node_name like concat('%', #{nodeName}, '%')</if>
        </where>
        order by template_id, node_order
    </select>

    <select id="selectNodeById" parameterType="Long" resultMap="DesignTemplateNodeResult">
        <include refid="selectNodeVo"/>
        where node_id = #{nodeId}
    </select>

    <select id="selectNodesByTemplateId" parameterType="Long" resultMap="DesignTemplateNodeResult">
        <include refid="selectNodeVo"/>
        where template_id = #{templateId}
        order by node_order
    </select>

    <insert id="insertNode" parameterType="DesignTemplateNode" useGeneratedKeys="true" keyProperty="nodeId">
        insert into t2_design_template_node(
            <if test="nodeId != null and nodeId != 0">node_id,</if>
            <if test="templateId != null">template_id,</if>
            <if test="nodeCode != null and nodeCode != ''">node_code,</if>
            <if test="nodeName != null and nodeName != ''">node_name,</if>
            <if test="nodeOrder != null">node_order,</if>
            <if test="parallelGroup != null">parallel_group,</if>
            <if test="responsibleRole != null">responsible_role,</if>
            <if test="timeLimit != null">time_limit,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="nodeId != null and nodeId != 0">#{nodeId},</if>
            <if test="templateId != null">#{templateId},</if>
            <if test="nodeCode != null and nodeCode != ''">#{nodeCode},</if>
            <if test="nodeName != null and nodeName != ''">#{nodeName},</if>
            <if test="nodeOrder != null">#{nodeOrder},</if>
            <if test="parallelGroup != null">#{parallelGroup},</if>
            <if test="responsibleRole != null">#{responsibleRole},</if>
            <if test="timeLimit != null">#{timeLimit},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateNode" parameterType="DesignTemplateNode">
        update t2_design_template_node
        <set>
            <if test="nodeName != null and nodeName != ''">node_name = #{nodeName},</if>
            <if test="nodeOrder != null">node_order = #{nodeOrder},</if>
            <if test="parallelGroup != null">parallel_group = #{parallelGroup},</if>
            <if test="responsibleRole != null">responsible_role = #{responsibleRole},</if>
            <if test="timeLimit != null">time_limit = #{timeLimit},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where node_id = #{nodeId}
    </update>

    <delete id="deleteNodeById" parameterType="Long">
        delete from t2_design_template_node where node_id = #{nodeId}
    </delete>

    <delete id="deleteNodesByTemplateId" parameterType="Long">
        delete from t2_design_template_node where template_id = #{templateId}
    </delete>

</mapper>
