<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.designtask1.mapper.DesignTaskNodeMapper">

    <resultMap type="DesignTaskNode" id="DesignTaskNodeResult">
        <id property="id" column="id" />
        <result property="taskId" column="task_id" />
        <result property="templateNodeId" column="template_node_id" />
        <result property="nodeCode" column="node_code" />
        <result property="nodeName" column="node_name" />
        <result property="nodeOrder" column="node_order" />
        <result property="parallelGroup" column="parallel_group" />
        <result property="status" column="status" />
        <result property="assigneeId" column="assignee_id" />
        <result property="assigneeName" column="assignee_name" />
        <result property="result" column="result" />
        <result property="startTime" column="start_time" />
        <result property="endTime" column="end_time" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="selectTaskNodeVo">
        select id, task_id, template_node_id, node_code, node_name, node_order, parallel_group, status, assignee_id, assignee_name, result, start_time, end_time, create_by, create_time
        from t2_design_task_node
    </sql>

    <select id="selectTaskNodeList" parameterType="DesignTaskNode" resultMap="DesignTaskNodeResult">
        <include refid="selectTaskNodeVo"/>
        <where>
            <if test="taskId != null">AND task_id = #{taskId}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by node_order
    </select>

    <select id="selectTaskNodeById" parameterType="Long" resultMap="DesignTaskNodeResult">
        <include refid="selectTaskNodeVo"/>
        where id = #{id}
    </select>

    <select id="selectNodesByTaskId" parameterType="Long" resultMap="DesignTaskNodeResult">
        <include refid="selectTaskNodeVo"/>
        where task_id = #{taskId}
        order by node_order
    </select>

    <insert id="insertTaskNode" parameterType="DesignTaskNode" useGeneratedKeys="true" keyProperty="id">
        insert into t2_design_task_node(
            <if test="id != null and id != 0">id,</if>
            <if test="taskId != null">task_id,</if>
            <if test="templateNodeId != null">template_node_id,</if>
            <if test="nodeCode != null and nodeCode != ''">node_code,</if>
            <if test="nodeName != null and nodeName != ''">node_name,</if>
            <if test="nodeOrder != null">node_order,</if>
            <if test="parallelGroup != null">parallel_group,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="assigneeId != null">assignee_id,</if>
            <if test="assigneeName != null">assignee_name,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="id != null and id != 0">#{id},</if>
            <if test="taskId != null">#{taskId},</if>
            <if test="templateNodeId != null">#{templateNodeId},</if>
            <if test="nodeCode != null and nodeCode != ''">#{nodeCode},</if>
            <if test="nodeName != null and nodeName != ''">#{nodeName},</if>
            <if test="nodeOrder != null">#{nodeOrder},</if>
            <if test="parallelGroup != null">#{parallelGroup},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="assigneeId != null">#{assigneeId},</if>
            <if test="assigneeName != null">#{assigneeName},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <insert id="insertTaskNodes">
        insert into t2_design_task_node(task_id, template_node_id, node_code, node_name, node_order, parallel_group, status, create_by, create_time)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.taskId}, #{item.templateNodeId}, #{item.nodeCode}, #{item.nodeName}, #{item.nodeOrder}, #{item.parallelGroup}, #{item.status}, #{item.createBy}, sysdate())
        </foreach>
    </insert>

    <update id="updateTaskNode" parameterType="DesignTaskNode">
        update t2_design_task_node
        <set>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="assigneeId != null">assignee_id = #{assigneeId},</if>
            <if test="assigneeName != null">assignee_name = #{assigneeName},</if>
            <if test="result != null">result = #{result},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteTaskNodeById" parameterType="Long">
        delete from t2_design_task_node where id = #{id}
    </delete>

    <delete id="deleteTaskNodesByTaskId" parameterType="Long">
        delete from t2_design_task_node where task_id = #{taskId}
    </delete>

</mapper>
