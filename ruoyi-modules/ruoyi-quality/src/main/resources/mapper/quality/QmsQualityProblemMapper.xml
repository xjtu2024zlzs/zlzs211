    <delete id="deleteQmsQualityProblemByProblemId" parameterType="Long">
        delete from qms_quality_problem where problem_id = #{problemId}
    </delete>

    <delete id="deleteQmsQualityProblemByProblemIds" parameterType="String">
        delete from qms_quality_problem where problem_id in 
        <foreach item="problemId" collection="array" open="(" separator="," close=")">
