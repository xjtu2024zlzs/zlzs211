    <sql id="selectQmsQualityProblemVo">
        select problem_id, problem_code, title, occur_time, product_model, involved_system, occur_part, component_code, severity, source, reporter, description, influence_scope, status, current_module_code, current_module_name, create_by, create_time, update_by, update_time, del_flag from qms_quality_problem
    </sql>

    <select id="selectQmsQualityProblemList" parameterType="QmsQualityProblem" resultMap="QmsQualityProblemResult">
        <include refid="selectQmsQualityProblemVo"/>
        <where>  
            <if test="problemCode != null  and problemCode != ''"> and problem_code = #{problemCode}</if>
            <if test="title != null  and title != ''"> and title = #{title}</if>
            <if test="occurTime != null "> and occur_time = #{occurTime}</if>
            <if test="productModel != null  and productModel != ''"> and product_model = #{productModel}</if>
            <if test="involvedSystem != null  and involvedSystem != ''"> and involved_system = #{involvedSystem}</if>
            <if test="occurPart != null  and occurPart != ''"> and occur_part = #{occurPart}</if>
            <if test="componentCode != null  and componentCode != ''"> and component_code = #{componentCode}</if>
            <if test="severity != null  and severity != ''"> and severity = #{severity}</if>
            <if test="source != null  and source != ''"> and source = #{source}</if>
            <if test="reporter != null  and reporter != ''"> and reporter = #{reporter}</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="influenceScope != null  and influenceScope != ''"> and influence_scope = #{influenceScope}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="currentModuleCode != null  and currentModuleCode != ''"> and current_module_code = #{currentModuleCode}</if>
            <if test="currentModuleName != null  and currentModuleName != ''"> and current_module_name like concat('%', #{currentModuleName}, '%')</if>
        </where>
    </select>
    
    <select id="selectQmsQualityProblemByProblemId" parameterType="Long" resultMap="QmsQualityProblemResult">
        <include refid="selectQmsQualityProblemVo"/>
        where problem_id = #{problemId}
    </select>

    <insert id="insertQmsQualityProblem" parameterType="QmsQualityProblem" useGeneratedKeys="true" keyProperty="problemId">
