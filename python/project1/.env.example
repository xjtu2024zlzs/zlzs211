# Copy this file to .env and paste real keys locally.
# Do not commit .env.

# Required only when running MagnetoGPT with DeepSeek models.
DEEPSEEK_API_KEY=

# Required only when running MagnetoGPT with OpenAI models.
OPENAI_API_KEY=

# RuoYi MySQL target database. The Java backend still owns business writes;
# this service only reads target schema/sample data for schema matching.
RUOYI_MYSQL_HOST=127.0.0.1
RUOYI_MYSQL_PORT=3306
RUOYI_MYSQL_DATABASE=ry-cloud
RUOYI_MYSQL_USER=root
RUOYI_MYSQL_PASSWORD=password
RUOYI_DOSSIER_TABLE_PREFIX=p1p_dossier_
